---
import CourseLayout from '../layouts/CourseLayout.astro';
import rawHtml from '../content/deep-dive-streaming.html?raw';

const base = import.meta.env.BASE_URL;
const html = rawHtml.replace(/href="\//g, `href="${base}`);
---

<CourseLayout title="Deep Dive: Streaming I/O" activeSlug="deep-dive-streaming" moduleBadge="Deep Dive">
  <Fragment set:html={html} />
</CourseLayout>

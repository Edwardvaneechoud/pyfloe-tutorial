---
import CourseLayout from '../layouts/CourseLayout.astro';
import rawHtml from '../content/interlude-wiring.html?raw';

const base = import.meta.env.BASE_URL;
const html = rawHtml.replace(/href="\//g, `href="${base}`);
---

<CourseLayout title="Wiring It All Together" activeSlug="interlude-wiring" moduleBadge="Interlude">
  <Fragment set:html={html} />
</CourseLayout>

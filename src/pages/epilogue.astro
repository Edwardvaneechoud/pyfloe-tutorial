---
import CourseLayout from '../layouts/CourseLayout.astro';
import rawHtml from '../content/epilogue.html?raw';

const base = import.meta.env.BASE_URL;
const html = rawHtml.replace(/href="\//g, `href="${base}`);
---

<CourseLayout title="Where Do You Go from Here?" activeSlug="epilogue" moduleBadge="Epilogue">
  <Fragment set:html={html} />
</CourseLayout>

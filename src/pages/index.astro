---
import LandingLayout from '../layouts/LandingLayout.astro';
import rawHtml from '../content/index.html?raw';

const base = import.meta.env.BASE_URL;
const html = rawHtml.replace(/href="\//g, `href="${base}`);
---

<LandingLayout title="Build Your Own DataFrame">
  <Fragment set:html={html} />
</LandingLayout>

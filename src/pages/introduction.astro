---
import CourseLayout from '../layouts/CourseLayout.astro';
import rawHtml from '../content/introduction.html?raw';

const base = import.meta.env.BASE_URL;
const html = rawHtml.replace(/href="\//g, `href="${base}`);
---

<CourseLayout title="Meet pyfloe" activeSlug="introduction" moduleBadge="Introduction">
  <Fragment set:html={html} />
</CourseLayout>

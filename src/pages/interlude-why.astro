---
import CourseLayout from '../layouts/CourseLayout.astro';
import rawHtml from '../content/interlude-why.html?raw';

const base = import.meta.env.BASE_URL;
const html = rawHtml.replace(/href="\//g, `href="${base}`);
---

<CourseLayout title="Why I Think This Is Interesting" activeSlug="interlude-why" moduleBadge="Interlude">
  <Fragment set:html={html} />
</CourseLayout>
